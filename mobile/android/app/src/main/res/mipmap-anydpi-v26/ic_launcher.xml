<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive launcher icon (API 26+). Foreground (white figure + heart +
     wordmark) over the indigo brand gradient; monochrome reuses the foreground
     for Android 13+ themed icons. Generated from healyn_app_icon.png via
     tool/generate_app_icon.py + tool/install_brand_assets.py. -->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@mipmap/ic_launcher_background" />
    <foreground android:drawable="@mipmap/ic_launcher_foreground" />
    <monochrome android:drawable="@mipmap/ic_launcher_foreground" />
</adaptive-icon>
