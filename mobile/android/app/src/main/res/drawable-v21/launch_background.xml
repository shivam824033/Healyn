<?xml version="1.0" encoding="utf-8"?>
<!-- Launch splash shown while the Flutter engine boots. The indigo brand
     gradient with the white Healyn logo card centred, flowing seamlessly into
     the in-app SplashScreen. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@drawable/splash_gradient" />
    <item>
        <bitmap
            android:gravity="center"
            android:src="@drawable/splash_logo" />
    </item>
</layer-list>
