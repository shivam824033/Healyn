# Healyn local development environment variables.
# Copy to `.env` and fill in the values you need.
# The defaults below assume the dev's existing local Docker containers:
#   - PostgreSQL 16 on localhost:5432, user `postgres` / pass `postgres`, DB `healyn`
#   - Redis 7 on localhost:6379 (no auth)
#   - MinIO on localhost:9000, `minioadmin` / `minioadmin`, bucket `healyn-files-dev`
#
# All real secrets in prod come from the cloud secret manager, NEVER this file.

# --- Spring profile ---
HEALYN_PROFILE=local
HEALYN_HTTP_PORT=8080

# --- PostgreSQL ---
HEALYN_DB_HOST=localhost
HEALYN_DB_PORT=5432
HEALYN_DB_NAME=healyn
HEALYN_DB_USER=postgres
HEALYN_DB_PASSWORD=postgres

# --- Redis ---
HEALYN_REDIS_HOST=localhost
HEALYN_REDIS_PORT=6379
HEALYN_REDIS_PASSWORD=
HEALYN_REDIS_DB=0

# --- S3 / MinIO ---
HEALYN_S3_ENDPOINT=http://localhost:9000
HEALYN_S3_REGION=us-east-1
HEALYN_S3_ACCESS_KEY=minioadmin
HEALYN_S3_SECRET_KEY=minioadmin
HEALYN_S3_BUCKET=healyn-files-dev

# --- Password hashing pepper (Argon2id) ---
# Generate: openssl rand -base64 32
HEALYN_PASSWORD_PEPPER=replace-me-with-32-bytes-base64-from-openssl

# --- JWT RS256 keypair ---
# Generate (PEM, PKCS#8):
#   openssl genpkey -algorithm RSA -out jwt-private.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -pubout -in jwt-private.pem -out jwt-public.pem
HEALYN_JWT_PRIVATE_KEY_PATH=./secrets/jwt-private.pem
HEALYN_JWT_PUBLIC_KEY_PATH=./secrets/jwt-public.pem

# --- FCM (Phase B/notifications module) ---
# Used by the real firebase-admin adapter (pending dependency approval). Until then the
# logging FcmSender is the default and no credentials are required.
HEALYN_FCM_CREDENTIALS_PATH=./secrets/fcm-service-account.json

# --- Notification outbox dispatcher (defaults shown; all optional) ---
# Bound from healyn.notifications.* — see notifications/config/NotificationProperties.
# HEALYN_NOTIFICATIONS_POLLER_ENABLED=true
# HEALYN_NOTIFICATIONS_POLL_INTERVAL_MS=2000
# HEALYN_NOTIFICATIONS_BATCH_SIZE=50
# HEALYN_NOTIFICATIONS_MAX_ATTEMPTS=5
# HEALYN_NOTIFICATIONS_BACKOFF_BASE_SECONDS=2
