# Healyn local development environment variables.
# Copy to `.env` and fill in the values you need.
# The defaults below assume the dev's existing local Docker containers:
#   - PostgreSQL 16 on localhost:5432, user `postgres` / pass `postgres`, DB `healyn`
#   - Redis 7 on localhost:6379 (no auth)
#   - MinIO on localhost:9000, `minioadmin` / `minioadmin`, bucket `healyn-files-dev`
#
# All real secrets in prod come from the cloud secret manager, NEVER this file.

# --- Spring profile ---
HEALYN_PROFILE=local
HEALYN_HTTP_PORT=8080
# prod only: Actuator (health/info/metrics) binds to this separate, internal-only port.
# Keep it off the public TLS gateway; point platform liveness/readiness probes here.
HEALYN_MANAGEMENT_PORT=9090

# --- PostgreSQL ---
HEALYN_DB_HOST=localhost
HEALYN_DB_PORT=5432
HEALYN_DB_NAME=healyn
HEALYN_DB_USER=postgres
HEALYN_DB_PASSWORD=postgres

# --- Redis ---
HEALYN_REDIS_HOST=localhost
HEALYN_REDIS_PORT=6379
HEALYN_REDIS_PASSWORD=
HEALYN_REDIS_DB=0

# --- S3 / MinIO ---
HEALYN_S3_ENDPOINT=http://localhost:9000
# Host the MOBILE DEVICE/EMULATOR uses to reach storage for presigned upload/download
# URLs. Leave blank to reuse HEALYN_S3_ENDPOINT (fine for same-host browsers). For a
# phone on your LAN set your machine's IP, e.g. http://192.168.1.20:9000; for the
# Android emulator use http://10.0.2.2:9000.
HEALYN_S3_PUBLIC_ENDPOINT=http://192.168.0.104:9000
HEALYN_S3_REGION=us-east-1
HEALYN_S3_ACCESS_KEY=minioadmin
HEALYN_S3_SECRET_KEY=minioadmin
HEALYN_S3_BUCKET=healyn-files-dev

# --- Password hashing pepper (Argon2id) ---
# Generate: openssl rand -base64 32
HEALYN_PASSWORD_PEPPER=replace-me-with-32-bytes-base64-from-openssl

# --- JWT RS256 keypair ---
# Generate (PEM, PKCS#8):
#   openssl genpkey -algorithm RSA -out jwt-private.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -pubout -in jwt-private.pem -out jwt-public.pem
HEALYN_JWT_PRIVATE_KEY_PATH=./secrets/jwt-private.pem
HEALYN_JWT_PUBLIC_KEY_PATH=./secrets/jwt-public.pem

# --- OTP delivery (auth module) ---
# EMAIL OTPs go over SMTP (SmtpOtpSender). Leave HEALYN_SMTP_HOST UNSET for local dev/CI —
# the console LoggingOtpSender is used there. Outside local/test the app fails fast if SMTP
# is unset, so email OTPs are never silently dropped. SMS OTP has no provider yet (SmsOtpSender
# throws); wire one before enabling phone-based signup/reset.
# HEALYN_SMTP_HOST=smtp.example.com
# HEALYN_SMTP_PORT=587
# HEALYN_SMTP_USERNAME=apikey
# HEALYN_SMTP_PASSWORD=replace-me
# HEALYN_SMTP_AUTH=true
# HEALYN_SMTP_STARTTLS=true
# HEALYN_OTP_EMAIL_FROM=no-reply@healyn.app
# HEALYN_OTP_EMAIL_SUBJECT=Your Healyn verification code

# --- FCM (notifications module) ---
# When set, the real FirebaseFcmSender (firebase-admin) is used to deliver push.
# Leave UNSET to fall back to the logging sender (local dev / CI). Service-account JSON
# from the Firebase console; never commit the real file.
HEALYN_FCM_CREDENTIALS_PATH=./secrets/fcm-service-account.json

# --- Notification outbox dispatcher (defaults shown; all optional) ---
# Bound from healyn.notifications.* — see notifications/config/NotificationProperties.
# HEALYN_NOTIFICATIONS_POLLER_ENABLED=true
# HEALYN_NOTIFICATIONS_POLL_INTERVAL_MS=2000
# HEALYN_NOTIFICATIONS_BATCH_SIZE=50
# HEALYN_NOTIFICATIONS_MAX_ATTEMPTS=5
# HEALYN_NOTIFICATIONS_BACKOFF_BASE_SECONDS=2
# Visibility timeout while a claimed row is being delivered; must exceed one sweep's duration.
# HEALYN_NOTIFICATIONS_LEASE_SECONDS=60
